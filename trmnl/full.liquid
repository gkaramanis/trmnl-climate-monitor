<div class="view view--full">
  <div class="layout">
    <div class="flex gap--large" style="align-items:center; height:100%;">

      <div style="flex:0 0 30%;">
        <div style="margin-bottom:24px;">
          <span class="label">Today</span>
          <div style="font-size:50px; font-weight:700; line-height:1.05;">{{ current_temp }}{{ units }}</div>
        </div>
        <div style="margin-bottom:24px;">
          <span class="label">{{ normal_window }} normal</span>
          <div style="font-size:34px; font-weight:600; line-height:1.05;">{{ normal_temp }}{{ units }}</div>
        </div>
        <div>
          <span class="label">Anomaly</span>
          <div style="font-size:34px; font-weight:600; line-height:1.05;">{{ anomaly_str }}</div>
        </div>
      </div>

      <div style="flex:1 1 70%;">{{ svg_full }}</div>

    </div>
  </div>

  <div class="title_bar">
    <span class="title">Climate Monitor · {{ location }}</span>
    <span class="instance">{{ year }} vs {{ normal_window }}</span>
  </div>
</div>
